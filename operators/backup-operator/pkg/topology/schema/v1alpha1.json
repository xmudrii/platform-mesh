{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://platform-mesh.io/backup-operator/topology/v1alpha1",
  "title": "topology.json v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "capturedAt",
    "hostCluster",
    "kcp",
    "cnpg",
    "openfga",
    "operatorVersion"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1alpha1"
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time"
    },
    "hostCluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kubernetesVersion", "namespace"],
      "properties": {
        "kubernetesVersion": { "type": "string" },
        "namespace":         { "type": "string" }
      }
    },
    "kcp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shardCount", "shards"],
      "properties": {
        "shardCount": {
          "type": "integer",
          "minimum": 1
        },
        "shards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "etcdRef", "logicalClusterIDsDigest"],
            "properties": {
              "name":                    { "type": "string" },
              "etcdRef":                 { "type": "string" },
              "logicalClusterIDsDigest": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "cnpg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clusters"],
      "properties": {
        "clusters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "specDigest", "majorVersion"],
            "properties": {
              "name":         { "type": "string" },
              "specDigest":   {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              },
              "majorVersion": { "type": "integer" }
            }
          }
        }
      }
    },
    "openfga": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stores"],
      "properties": {
        "stores": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "modelDigest"],
            "properties": {
              "name":        { "type": "string" },
              "modelDigest": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "operatorVersion": {
      "type": "string"
    }
  }
}
