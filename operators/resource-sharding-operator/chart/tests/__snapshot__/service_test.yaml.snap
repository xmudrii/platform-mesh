renders webhook service with default values (webhook enabled):
  1: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
      name: rso-resource-sharding-operator-webhook
      namespace: NAMESPACE
    spec:
      ports:
        - name: webhook
          port: 443
          protocol: TCP
          targetPort: 9443
      selector:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/name: resource-sharding-operator
renders with custom webhook service name:
  1: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
      name: my-custom-webhook
      namespace: NAMESPACE
    spec:
      ports:
        - name: webhook
          port: 443
          protocol: TCP
          targetPort: 9443
      selector:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/name: resource-sharding-operator
