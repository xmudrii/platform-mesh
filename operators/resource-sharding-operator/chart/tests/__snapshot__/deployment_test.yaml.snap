renders with pod annotations and labels:
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
      name: rso-resource-sharding-operator
      namespace: NAMESPACE
    spec:
      replicas: 1
      selector:
        matchLabels:
          app.kubernetes.io/instance: rso
          app.kubernetes.io/name: resource-sharding-operator
      template:
        metadata:
          annotations:
            prometheus.io/scrape: "true"
          labels:
            app.kubernetes.io/instance: rso
            app.kubernetes.io/name: resource-sharding-operator
            team: platform
        spec:
          containers:
            - args:
                - operator
                - --leader-elect
                - --metrics-bind-address=:9090
                - --health-probe-bind-address=:8090
                - --kcp-api-export-endpoint-slice-name=sharding.platform-mesh.io
                - --webhook-enabled=true
              env:
                - name: POD_NAMESPACE
                  valueFrom:
                    fieldRef:
                      fieldPath: metadata.namespace
                - name: WEBHOOK_SERVICE_NAME
                  value: rso-resource-sharding-operator-webhook
              image: ghcr.io/platform-mesh/resource-sharding-operator:v0.1.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                httpGet:
                  path: /healthz
                  port: health
                initialDelaySeconds: 15
                periodSeconds: 20
              name: manager
              ports:
                - containerPort: 9090
                  name: metrics
                  protocol: TCP
                - containerPort: 8090
                  name: health
                  protocol: TCP
                - containerPort: 9443
                  name: webhook
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /readyz
                  port: health
                initialDelaySeconds: 5
                periodSeconds: 10
              resources:
                limits:
                  memory: 256Mi
                requests:
                  cpu: 50m
                  memory: 128Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
          securityContext:
            runAsNonRoot: true
            seccompProfile:
              type: RuntimeDefault
          serviceAccountName: rso-resource-sharding-operator
          terminationGracePeriodSeconds: 10
