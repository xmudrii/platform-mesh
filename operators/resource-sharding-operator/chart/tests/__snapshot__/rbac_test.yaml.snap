renders all RBAC resources with default values:
  1: |
    aggregationRule:
      clusterRoleSelectors:
        - matchLabels:
            sharding.platform-mesh.io/aggregate-to-operator: "true"
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
      name: rso-resource-sharding-operator
    rules: []
  2: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
        sharding.platform-mesh.io/aggregate-to-operator: "true"
      name: rso-resource-sharding-operator-base
    rules:
      - apiGroups:
          - sharding.platform-mesh.io
        resources:
          - resourceshardings
        verbs:
          - get
          - list
          - watch
          - create
          - update
          - patch
          - delete
      - apiGroups:
          - sharding.platform-mesh.io
        resources:
          - resourceshardings/status
        verbs:
          - get
          - update
          - patch
      - apiGroups:
          - sharding.platform-mesh.io
        resources:
          - resourceshardings/finalizers
        verbs:
          - update
      - apiGroups:
          - admissionregistration.k8s.io
        resources:
          - mutatingwebhookconfigurations
        verbs:
          - get
          - list
          - watch
          - create
          - update
          - patch
          - delete
      - apiGroups:
          - authorization.k8s.io
        resources:
          - selfsubjectaccessreviews
        verbs:
          - create
      - apiGroups:
          - ""
        resources:
          - events
        verbs:
          - create
          - patch
  3: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRoleBinding
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
      name: rso-resource-sharding-operator
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: rso-resource-sharding-operator
    subjects:
      - kind: ServiceAccount
        name: rso-resource-sharding-operator
        namespace: NAMESPACE
  4: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: Role
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
      name: rso-resource-sharding-operator-leader-election
      namespace: NAMESPACE
    rules:
      - apiGroups:
          - coordination.k8s.io
        resources:
          - leases
        verbs:
          - get
          - list
          - watch
          - create
          - update
          - patch
          - delete
  5: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: RoleBinding
    metadata:
      labels:
        app.kubernetes.io/instance: rso
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: resource-sharding-operator
        app.kubernetes.io/version: v0.1.0
        helm.sh/chart: resource-sharding-operator-0.1.0
      name: rso-resource-sharding-operator-leader-election
      namespace: NAMESPACE
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: Role
      name: rso-resource-sharding-operator-leader-election
    subjects:
      - kind: ServiceAccount
        name: rso-resource-sharding-operator
        namespace: NAMESPACE
